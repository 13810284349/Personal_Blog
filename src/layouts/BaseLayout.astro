---
import "../styles/global.css";
import { site } from "@lib/site";

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  image?: string;
  noindex?: boolean;
  type?: "website" | "article";
  article?: {
    publishedTime: Date;
    modifiedTime: Date;
    authorUrl: string;
    tags: string[];
  };
  structuredData?: Record<string, unknown>;
}

const {
  title = site.name,
  description = site.description,
  currentPath = Astro.url.pathname,
  image,
  noindex = false,
  type = "website",
  article,
  structuredData
} = Astro.props;
const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
const canonicalPath = currentPath === "/" ? "/" : currentPath.replace(/\/+$/, "");
const canonicalUrl = new URL(canonicalPath || "/", site.url).toString();
const rssUrl = new URL("/rss.xml", site.url).toString();
const imageUrl = image ? new URL(image, site.url).toString() : undefined;
const articleAuthorUrl = article
  ? new URL(article.authorUrl, site.url).toString()
  : "";
const jsonLd = structuredData
  ? JSON.stringify(structuredData).replace(/</g, "\\u003c")
  : undefined;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} RSS`} href={rssUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    {
      type === "article" && article && (
        <>
          <meta property="article:published_time" content={article.publishedTime.toISOString()} />
          <meta property="article:modified_time" content={article.modifiedTime.toISOString()} />
          <meta property="article:author" content={articleAuthorUrl} />
          {article.tags.map((tag) => (
            <meta property="article:tag" content={tag} />
          ))}
        </>
      )
    }
    <meta name="twitter:card" content={imageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    {jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd}></script>}
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label={`${site.name} 首页`}>
          <span class="brand-title">{site.name}</span>
          <span class="brand-subtitle">{site.subtitle}</span>
        </a>
        <nav class="site-nav" aria-label="主导航">
          {
            site.nav.map((item) => (
              <a
                href={item.href}
                aria-current={
                  currentPath === item.href ||
                  (item.href !== "/" && currentPath.startsWith(item.href))
                    ? "page"
                    : undefined
                }
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>
      <main class="page">
        <slot />
      </main>
      <footer class="site-footer">
        <span>© {new Date().getFullYear()} {site.author}. Built with Astro, Supabase and Netlify.</span>
      </footer>
    </div>
  </body>
</html>
