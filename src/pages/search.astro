---
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatDate, getPublishedPosts } from "@lib/posts";

type SearchPostMeta = {
  slug: string;
  title: string;
  description: string;
  publishedAt: string;
  publishedDate: string;
  tags: string[];
  url: string;
};

const posts = await getPublishedPosts();
const searchPosts: SearchPostMeta[] = posts.map((post) => ({
  slug: post.id,
  title: post.data.title,
  description: post.data.description,
  publishedAt: post.data.publishedAt.toISOString(),
  publishedDate: formatDate(post.data.publishedAt),
  tags: post.data.tags,
  url: `/posts/${encodeURIComponent(post.id)}`
}));

const searchMetadataJson = JSON.stringify(searchPosts).replace(/</g, "\\u003c");
---

<BaseLayout title="搜索" description="搜索自然选择的已发布文章。" currentPath="/search">
  <section class="intro" aria-labelledby="search-title">
    <div>
      <p class="eyebrow">Search</p>
      <h1 id="search-title" class="page-title">寻找旧判断。</h1>
      <p class="page-description">在旧文章里，重新捞起一个念头。</p>
    </div>
    <aside class="index-mark" aria-label="搜索索引统计">
      <strong>{posts.length.toString().padStart(2, "0")}</strong>
      <span>篇已发布文章</span>
      <span>全文索引</span>
    </aside>
  </section>

  <section class="search-panel" aria-labelledby="search-form-title">
    <h2 id="search-form-title" class="sr-only">站内搜索</h2>
    <form class="search-form" data-search-form role="search">
      <label class="search-label" for="site-search">搜索关键词</label>
      <div class="search-input-row">
        <input
          id="site-search"
          type="search"
          name="q"
          data-search-input
          autocomplete="off"
          placeholder="输入关键词"
        />
        <button class="ghost-button" type="submit">搜索</button>
      </div>
    </form>
    <p class="search-status" data-search-status aria-live="polite"></p>
  </section>

  <p class="search-empty" data-search-empty hidden>没有找到相关文章。换一个词试试。</p>
  <div class="search-results" data-search-results aria-label="搜索结果"></div>

  <script id="search-metadata" type="application/json" set:html={searchMetadataJson} is:inline></script>
  <script is:inline>
    const metadataElement = document.getElementById("search-metadata");
    const searchInput = document.querySelector("[data-search-input]");
    const searchForm = document.querySelector("[data-search-form]");
    const statusElement = document.querySelector("[data-search-status]");
    const resultsElement = document.querySelector("[data-search-results]");
    const emptyElement = document.querySelector("[data-search-empty]");
    const posts = JSON.parse(metadataElement?.textContent ?? "[]");

    const escapeHtml = (value) =>
      String(value).replace(/[&<>"']/g, (char) => {
        const entities = {
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;"
        };
        return entities[char];
      });

    const safeDecode = (value) => {
      try {
        return decodeURIComponent(value);
      } catch {
        return value;
      }
    };

    const normalizePath = (value) => {
      try {
        const url = new URL(value, window.location.origin);
        return (url.pathname || "/").replace(/\/+$/, "") || "/";
      } catch {
        return String(value).split("#")[0].split("?")[0].replace(/\/+$/, "") || "/";
      }
    };

    const postByPath = new Map();

    for (const post of posts) {
      const paths = [
        post.url,
        `/posts/${post.slug}`,
        `/posts/${encodeURIComponent(post.slug)}`
      ];

      for (const path of paths) {
        const normalizedPath = normalizePath(path);
        postByPath.set(normalizedPath, post);
        postByPath.set(safeDecode(normalizedPath), post);
      }
    }

    let pagefindPromise;
    let activeSearchId = 0;

    function buildPostUrl(post) {
      return `/posts/${encodeURIComponent(post.slug)}`;
    }

    function getPostForUrl(url) {
      const path = normalizePath(url);
      return postByPath.get(path) ?? postByPath.get(safeDecode(path));
    }

    function renderResults(results) {
      resultsElement.innerHTML = results
        .map(({ post, url, excerpt }) => {
          const tags = post.tags
            .map((tag) => `<span class="tag">${escapeHtml(tag)}</span>`)
            .join("");
          const tagsHtml = tags
            ? `<div class="search-tags" aria-label="文章标签">${tags}</div>`
            : "";

          return `
            <a class="search-result" href="${escapeHtml(url)}">
              <time class="post-date" datetime="${escapeHtml(post.publishedAt)}">
                ${escapeHtml(post.publishedDate)}
              </time>
              <article>
                <h2>${escapeHtml(post.title)}</h2>
                <p class="search-snippet">${excerpt}</p>
                ${tagsHtml}
              </article>
            </a>
          `;
        })
        .join("");
    }

    function updateUrl(query) {
      const url = new URL(window.location.href);

      if (query) {
        url.searchParams.set("q", query);
      } else {
        url.searchParams.delete("q");
      }

      window.history.replaceState({}, "", url);
    }

    function renderAllPosts() {
      const results = posts.map((post) => ({
        post,
        url: buildPostUrl(post),
        excerpt: escapeHtml(post.description)
      }));

      renderResults(results);
      emptyElement.hidden = results.length > 0;
      statusElement.textContent = `共 ${results.length} 篇已发布文章`;
    }

    async function loadPagefind() {
      if (!pagefindPromise) {
        pagefindPromise = import("/pagefind/pagefind.js")
          .then(async (pagefind) => {
            await pagefind.init();
            return pagefind;
          })
          .catch((error) => {
            pagefindPromise = undefined;
            throw error;
          });
      }

      return pagefindPromise;
    }

    async function runSearch(query) {
      const trimmedQuery = query.trim();
      const searchId = ++activeSearchId;
      updateUrl(trimmedQuery);

      if (!trimmedQuery) {
        renderAllPosts();
        return;
      }

      statusElement.textContent = `正在搜索“${trimmedQuery}”...`;
      emptyElement.hidden = true;

      try {
        const pagefind = await loadPagefind();
        const search = await pagefind.debouncedSearch(trimmedQuery);

        if (searchId !== activeSearchId || search === null) {
          return;
        }

        const loadedResults = await Promise.all(
          search.results.map((result) => result.data())
        );

        if (searchId !== activeSearchId) {
          return;
        }

        const results = loadedResults
          .map((result) => {
            const post = getPostForUrl(result.url);

            if (!post) {
              return null;
            }

            return {
              post,
              url: result.url || buildPostUrl(post),
              excerpt: result.excerpt || escapeHtml(post.description)
            };
          })
          .filter(Boolean);

        renderResults(results);
        emptyElement.hidden = results.length > 0;
        statusElement.textContent = `找到 ${results.length} 篇与“${trimmedQuery}”相关的文章`;
      } catch {
        if (searchId !== activeSearchId) {
          return;
        }

        resultsElement.innerHTML = "";
        emptyElement.hidden = true;
        statusElement.textContent =
          "搜索索引还没有生成。请先运行 npm run build，再用 npm run preview 查看搜索。";
      }
    }

    if (
      searchInput instanceof HTMLInputElement &&
      searchForm instanceof HTMLFormElement &&
      statusElement &&
      resultsElement &&
      emptyElement
    ) {
      const initialQuery = new URLSearchParams(window.location.search).get("q") ?? "";
      searchInput.value = initialQuery;
      void runSearch(initialQuery);

      searchInput.addEventListener("focus", () => {
        if (!searchInput.value.trim()) {
          void loadPagefind().catch(() => {});
        }
      });

      searchInput.addEventListener("input", () => {
        void runSearch(searchInput.value);
      });

      searchForm.addEventListener("submit", (event) => {
        event.preventDefault();
        void runSearch(searchInput.value);
        searchInput.blur();
      });
    }
  </script>
</BaseLayout>
