---
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatDate, getPublishedPosts, type PostEntry } from "@lib/posts";

type ArchiveMonth = {
  month: number;
  label: string;
  posts: PostEntry[];
};

type ArchiveYear = {
  year: number;
  months: ArchiveMonth[];
};

const posts = await getPublishedPosts();
const archiveMap = new Map<number, Map<number, PostEntry[]>>();

for (const post of posts) {
  const year = post.data.publishedAt.getFullYear();
  const month = post.data.publishedAt.getMonth() + 1;
  let yearMap = archiveMap.get(year);

  if (!yearMap) {
    yearMap = new Map<number, PostEntry[]>();
    archiveMap.set(year, yearMap);
  }

  let monthPosts = yearMap.get(month);
  if (!monthPosts) {
    monthPosts = [];
    yearMap.set(month, monthPosts);
  }

  monthPosts.push(post);
}

const archiveYears: ArchiveYear[] = [...archiveMap.entries()]
  .sort(([a], [b]) => b - a)
  .map(([year, months]) => ({
    year,
    months: [...months.entries()]
      .sort(([a], [b]) => b - a)
      .map(([month, monthPosts]) => ({
        month,
        label: `${month.toString().padStart(2, "0")} 月`,
        posts: monthPosts
      }))
  }));
---

<BaseLayout title="归档" description="按时间浏览自然选择的文章。">
  <section class="intro" aria-labelledby="archive-title">
    <div>
      <p class="eyebrow">Archive</p>
      <h1 id="archive-title" class="page-title">时间归档。</h1>
      <p class="page-description">把已发布的笔记按年月收好，方便回到它们写下来的时刻。</p>
    </div>
    <aside class="index-mark" aria-label="归档统计">
      <strong>{posts.length.toString().padStart(2, "0")}</strong>
      <span>篇已发布文章</span>
      <span>{archiveYears.length} 个年份</span>
    </aside>
  </section>

  <div class="archive-list" aria-label="文章归档">
    {
      archiveYears.map((yearGroup) => (
        <section class="archive-year" aria-labelledby={`archive-year-${yearGroup.year}`}>
          <h2 id={`archive-year-${yearGroup.year}`}>{yearGroup.year}</h2>
          <div class="archive-months">
            {
              yearGroup.months.map((monthGroup) => (
                <section
                  class="archive-month"
                  aria-labelledby={`archive-month-${yearGroup.year}-${monthGroup.month}`}
                >
                  <h3 id={`archive-month-${yearGroup.year}-${monthGroup.month}`}>
                    {monthGroup.label}
                  </h3>
                  <div class="archive-entries">
                    {
                      monthGroup.posts.map((post) => (
                        <a class="archive-entry" href={`/posts/${post.id}`}>
                          <time datetime={post.data.publishedAt.toISOString()}>
                            {formatDate(post.data.publishedAt)}
                          </time>
                          <article>
                            <h4>{post.data.title}</h4>
                            <p>{post.data.description}</p>
                          </article>
                        </a>
                      ))
                    }
                  </div>
                </section>
              ))
            }
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
