---
import Comments from "@components/Comments.astro";
import Engagement from "@components/Engagement.astro";
import TagList from "@components/TagList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { render } from "astro:content";
import { formatDate, getPublishedPosts, readingTime } from "@lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  currentPath={`/posts/${post.id}`}
>
  <article>
    <header class="article-header">
      <p class="eyebrow">Post</p>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
      <div class="meta-line">
        <time datetime={post.data.publishedAt.toISOString()}>
          {formatDate(post.data.publishedAt)}
        </time>
        <span>{readingTime(post.body ?? "")}</span>
        {
          post.data.updatedAt && (
            <span>更新于 {formatDate(post.data.updatedAt)}</span>
          )
        }
      </div>
      <TagList tags={post.data.tags} />
    </header>

    <div class="article-grid">
      <div>
        <div class="prose">
          <Content />
        </div>
        <Comments slug={post.id} />
      </div>
      <aside class="article-aside">
        <Engagement slug={post.id} />
        <a class="tag" href="/">返回文章列表</a>
      </aside>
    </div>
  </article>
</BaseLayout>
