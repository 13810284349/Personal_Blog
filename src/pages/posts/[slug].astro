---
import Comments from "@components/Comments.astro";
import Engagement from "@components/Engagement.astro";
import ArticleToc from "@components/ArticleToc.astro";
import HeadingH2 from "@components/HeadingH2.astro";
import HeadingH3 from "@components/HeadingH3.astro";
import RelatedPosts from "@components/RelatedPosts.astro";
import TagList from "@components/TagList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { render } from "astro:content";
import { formatDate, getPublishedPosts, readingTime } from "@lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post, index) => {
    const currentTags = new Set(post.data.tags);
    const relatedPosts =
      currentTags.size === 0
        ? []
        : posts
            .filter((candidate) => candidate.id !== post.id)
            .map((candidate) => {
              const candidateTags = new Set(candidate.data.tags);
              let sharedTagsCount = 0;

              for (const tag of candidateTags) {
                if (currentTags.has(tag)) {
                  sharedTagsCount += 1;
                }
              }

              return { post: candidate, sharedTagsCount };
            })
            .filter(({ sharedTagsCount }) => sharedTagsCount > 0)
            .sort(
              (a, b) =>
                b.sharedTagsCount - a.sharedTagsCount ||
                b.post.data.publishedAt.getTime() -
                  a.post.data.publishedAt.getTime()
            )
            .slice(0, 3)
            .map(({ post }) => post);

    return {
      params: { slug: post.id },
      props: {
        post,
        previousPost: posts[index - 1] ?? null,
        nextPost: posts[index + 1] ?? null,
        relatedPosts
      }
    };
  });
}

const { post, previousPost, nextPost, relatedPosts } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter(
  (heading) => heading.depth === 2 || heading.depth === 3
);
const hasAdjacentPosts = previousPost || nextPost;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  currentPath={`/posts/${post.id}`}
  type="article"
>
  <article>
    <header class="article-header">
      <p class="eyebrow">Post</p>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
      <div class="meta-line">
        <time datetime={post.data.publishedAt.toISOString()}>
          {formatDate(post.data.publishedAt)}
        </time>
        <span>{readingTime(post.body ?? "")}</span>
        {
          post.data.updatedAt && (
            <span>更新于 {formatDate(post.data.updatedAt)}</span>
          )
        }
      </div>
      <TagList tags={post.data.tags} />
    </header>

    <div class="article-grid">
      <div>
        <ArticleToc headings={tocHeadings} variant="mobile" />
        <div class="prose">
          <Content components={{ h2: HeadingH2, h3: HeadingH3 }} />
        </div>
        <RelatedPosts posts={relatedPosts} />
        {
          hasAdjacentPosts && (
            <nav class="post-nav" aria-label="相邻文章">
              {
                previousPost && (
                  <a class="post-nav-link post-nav-link-previous" href={`/posts/${previousPost.id}`}>
                    <span class="post-nav-label">上一篇</span>
                    <strong>{previousPost.data.title}</strong>
                    <time datetime={previousPost.data.publishedAt.toISOString()}>
                      {formatDate(previousPost.data.publishedAt)}
                    </time>
                  </a>
                )
              }
              {
                nextPost && (
                  <a class="post-nav-link post-nav-link-next" href={`/posts/${nextPost.id}`}>
                    <span class="post-nav-label">下一篇</span>
                    <strong>{nextPost.data.title}</strong>
                    <time datetime={nextPost.data.publishedAt.toISOString()}>
                      {formatDate(nextPost.data.publishedAt)}
                    </time>
                  </a>
                )
              }
            </nav>
          )
        }
        <Comments slug={post.id} />
      </div>
      <aside class="article-aside">
        <ArticleToc headings={tocHeadings} variant="desktop" />
        <Engagement slug={post.id} />
        <a class="tag" href="/">返回文章列表</a>
      </aside>
    </div>
  </article>
</BaseLayout>
