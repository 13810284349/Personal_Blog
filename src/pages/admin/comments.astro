---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedPosts } from "@lib/posts";

type AdminPostMeta = {
  slug: string;
  title: string;
  url: string;
};

const posts = await getPublishedPosts();
const adminPosts: AdminPostMeta[] = posts.map((post) => ({
  slug: post.id,
  title: post.data.title,
  url: `/posts/${encodeURIComponent(post.id)}`
}));
const adminPostsJson = JSON.stringify(adminPosts).replace(/</g, "\\u003c");
---

<BaseLayout title="评论审核" description="审核自然选择的博客评论。" noindex>
  <section class="intro">
    <div>
      <p class="eyebrow">Admin</p>
      <h1 class="page-title">评论审核。</h1>
      <p class="page-description">按状态和关键词维护评论。token 只保存在当前浏览器会话中。</p>
    </div>
  </section>

  <section class="admin-panel" data-admin-comments>
    <form class="admin-filter-form" data-admin-form>
      <div class="field-grid">
        <div class="field">
          <label for="admin-token">审核 Token</label>
          <input id="admin-token" data-admin-token type="password" autocomplete="current-password" />
        </div>
        <div class="field">
          <label for="admin-query">关键词</label>
          <input
            id="admin-query"
            data-admin-query
            type="search"
            autocomplete="off"
            placeholder="昵称、正文、文章 slug、评论 ID"
          />
        </div>
      </div>
      <div class="admin-toolbar">
        <fieldset class="status-filter">
          <legend>状态</legend>
          <div class="status-tabs">
            <label>
              <input data-admin-status type="radio" name="admin-status" value="pending" checked />
              <span class="status-tab">
                <span class="status-tab-text">待审核</span>
                <strong class="status-count" data-admin-count="pending">--</strong>
              </span>
            </label>
            <label>
              <input data-admin-status type="radio" name="admin-status" value="approved" />
              <span class="status-tab">
                <span class="status-tab-text">已通过</span>
                <strong class="status-count" data-admin-count="approved">--</strong>
              </span>
            </label>
            <label>
              <input data-admin-status type="radio" name="admin-status" value="rejected" />
              <span class="status-tab">
                <span class="status-tab-text">已拒绝</span>
                <strong class="status-count" data-admin-count="rejected">--</strong>
              </span>
            </label>
          </div>
        </fieldset>
        <button class="primary-button" type="submit" data-admin-load>载入评论</button>
      </div>
    </form>
    <p class="form-note" data-admin-note aria-live="polite"></p>
    <div class="admin-list" data-admin-list></div>
  </section>

  <script id="admin-post-metadata" type="application/json" set:html={adminPostsJson} is:inline></script>
  <script>
    type AdminComment = {
      id: string;
      post_slug: string;
      author_name: string;
      author_email: string | null;
      author_website: string | null;
      body: string;
      status: string;
      created_at: string;
      reviewed_at: string | null;
    };

    type AdminPostMeta = {
      slug: string;
      title: string;
      url: string;
    };

    type AdminCounts = {
      pending: number;
      approved: number;
      rejected: number;
    };

    const root = document.querySelector("[data-admin-comments]");
    const form = root?.querySelector("[data-admin-form]");
    const tokenInput = root?.querySelector("[data-admin-token]");
    const queryInput = root?.querySelector("[data-admin-query]");
    const note = root?.querySelector("[data-admin-note]");
    const list = root?.querySelector("[data-admin-list]");
    const countElements = root?.querySelectorAll("[data-admin-count]");
    const postMetadataElement = document.getElementById("admin-post-metadata");
    const storageKey = "natural-selection-admin-token";
    const initialSearchParams = new URLSearchParams(window.location.search);
    const initialQuery = initialSearchParams.get("q")?.trim() ?? "";
    const hasInitialFilters = initialSearchParams.has("status") || initialSearchParams.has("q");
    const uuidPattern = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
    const statusLabels: Record<string, string> = {
      pending: "待审核",
      approved: "已通过",
      rejected: "已拒绝"
    };
    const actionLabels: Record<string, string> = {
      pending: "恢复待审",
      approved: "通过",
      rejected: "拒绝"
    };
    const reviewResultLabels: Record<string, string> = {
      approved: "已通过这条评论。",
      rejected: "已拒绝这条评论。"
    };
    const posts = JSON.parse(postMetadataElement?.textContent ?? "[]") as AdminPostMeta[];
    const postBySlug = new Map(posts.map((post) => [post.slug, post]));

    function isCommentIdQuery(value: string) {
      return uuidPattern.test(value);
    }

    function getInitialStatus() {
      const status = initialSearchParams.get("status");
      return status && status in statusLabels ? status : "pending";
    }

    function setStatus(value: string) {
      const statusInput = root?.querySelector(`[data-admin-status][value="${value}"]`);
      if (statusInput instanceof HTMLInputElement) statusInput.checked = true;
    }

    function saveToken() {
      if (tokenInput instanceof HTMLInputElement) {
        sessionStorage.setItem(storageKey, tokenInput.value);
      }
    }

    if (tokenInput instanceof HTMLInputElement) {
      tokenInput.value = sessionStorage.getItem(storageKey) ?? "";
      tokenInput.addEventListener("change", () => {
        saveToken();
        if (getToken()) {
          loadComments();
        } else {
          setTokenPromptNote();
        }
      });
      tokenInput.addEventListener("keydown", (event) => {
        if (event.key !== "Enter") return;
        event.preventDefault();
        saveToken();
        if (form instanceof HTMLFormElement) {
          form.requestSubmit();
        } else {
          loadComments();
        }
      });
    }

    setStatus(getInitialStatus());

    if (queryInput instanceof HTMLInputElement) {
      queryInput.value = initialQuery;
    }

    function getToken() {
      return tokenInput instanceof HTMLInputElement ? tokenInput.value.trim() : "";
    }

    function getStatus() {
      const statusInput = root?.querySelector("[data-admin-status]:checked");
      return statusInput instanceof HTMLInputElement ? statusInput.value : "pending";
    }

    function getQuery() {
      return queryInput instanceof HTMLInputElement ? queryInput.value.trim() : "";
    }

    function setNote(message: string, link?: { href: string; text: string }) {
      if (!note) return;
      note.textContent = "";
      note.append(document.createTextNode(message));

      if (link) {
        const anchor = document.createElement("a");
        anchor.className = "admin-note-link";
        anchor.href = link.href;
        anchor.textContent = link.text;
        note.append(" ", anchor);
      }
    }

    function getSearchSuffix(query: string) {
      if (!query) return "";
      const label = isCommentIdQuery(query) ? "评论 ID" : "关键词";
      return `，${label}“${query}”`;
    }

    function setTokenPromptNote() {
      if (getToken()) return;
      setNote(
        isCommentIdQuery(initialQuery)
          ? "输入审核 token 后将载入这条评论。"
          : hasInitialFilters
            ? "输入审核 token 后将按当前条件载入评论。"
            : "输入审核 token 后将载入待审列表。"
      );
    }

    function renderStatusCounts(counts: unknown) {
      if (!counts || typeof counts !== "object") return;
      const values = counts as Partial<Record<keyof AdminCounts, unknown>>;

      for (const element of countElements ?? []) {
        if (!(element instanceof HTMLElement)) continue;
        const status = element.dataset.adminCount as keyof AdminCounts | undefined;
        if (!status) continue;

        const value = values[status];
        const count = typeof value === "number" && Number.isFinite(value) ? value : 0;
        element.textContent = count.toLocaleString("zh-CN");
      }
    }

    function getEmptyNoteMessage(status: string, query: string) {
      if (isCommentIdQuery(query)) {
        return `这条评论已处理，或不在“${statusLabels[status] ?? status}”筛选下。`;
      }

      if (status === "pending" && !query) {
        return "当前没有待审评论。";
      }

      return `没有符合条件的${statusLabels[status] ?? status}评论${getSearchSuffix(query)}。`;
    }

    function formatDateTime(value: string | null) {
      if (!value) return "";
      return new Date(value).toLocaleString("zh-CN");
    }

    function getPostUrl(slug: string) {
      return postBySlug.get(slug)?.url ?? `/posts/${encodeURIComponent(slug)}`;
    }

    function updateLocationFilter(status: string, query: string) {
      const params = new URLSearchParams(window.location.search);
      params.set("status", status);

      if (query) {
        params.set("q", query);
      } else {
        params.delete("q");
      }

      const nextUrl = `${window.location.pathname}?${params.toString()}${window.location.hash}`;
      window.history.replaceState(null, "", nextUrl);
    }

    function createPostElement(slug: string) {
      const post = postBySlug.get(slug);
      const element = document.createElement(post ? "a" : "span");
      element.className = "admin-post-link";
      element.textContent = post ? post.title : slug;
      element.title = slug;

      if (post && element instanceof HTMLAnchorElement) {
        element.href = post.url;
      }

      return element;
    }

    function renderContact(comment: AdminComment) {
      const contact = document.createElement("p");
      contact.className = "admin-contact form-note";

      const email = comment.author_email ? `邮箱：${comment.author_email}` : "邮箱：未留";
      const website = comment.author_website ? `网站：${comment.author_website}` : "网站：未留";
      contact.textContent = `${email} · ${website}`;

      return contact;
    }

    function renderComment(comment: AdminComment) {
      const item = document.createElement("article");
      item.className = "admin-comment";

      const meta = document.createElement("div");
      meta.className = "admin-comment-meta";

      const status = document.createElement("span");
      status.className = `status-badge status-${comment.status}`;
      status.textContent = statusLabels[comment.status] ?? comment.status;

      const post = createPostElement(comment.post_slug);

      const createdAt = document.createElement("time");
      createdAt.dateTime = comment.created_at;
      createdAt.textContent = formatDateTime(comment.created_at);

      meta.append(status, post, createdAt);

      if (comment.reviewed_at) {
        const reviewedAt = document.createElement("span");
        reviewedAt.textContent = `审核：${formatDateTime(comment.reviewed_at)}`;
        meta.append(reviewedAt);
      }

      const author = document.createElement("h2");
      author.className = "admin-comment-author";
      author.textContent = comment.author_name;

      const body = document.createElement("p");
      body.className = "admin-comment-body";
      body.textContent = comment.body;

      const contact = renderContact(comment);
      const actions = document.createElement("div");
      actions.className = "admin-actions";

      for (const action of [
        ["approved", "primary-button"],
        ["rejected", "ghost-button"],
        ["pending", "ghost-button"]
      ] as const) {
        const button = document.createElement("button");
        button.className = action[1];
        button.type = "button";
        button.dataset.nextStatus = action[0];
        button.disabled = comment.status === action[0];
        button.textContent =
          comment.status === action[0]
            ? `${actionLabels[action[0]]}（当前）`
            : actionLabels[action[0]];
        actions.append(button);
      }

      item.append(meta, author, body, contact, actions);

      for (const button of item.querySelectorAll("[data-next-status]")) {
        button.addEventListener("click", async () => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.disabled = true;
          await updateComment(comment.id, button.dataset.nextStatus);
        });
      }

      return item;
    }

    function renderEmptyState(status: string, query: string) {
      const isDirectLookup = isCommentIdQuery(query);
      const isPendingQueue = status === "pending" && !query;
      const empty = document.createElement("div");
      empty.className = "admin-empty";

      const title = document.createElement("p");
      title.className = "admin-empty-title";
      title.textContent = isDirectLookup
        ? "已处理"
        : isPendingQueue
          ? "当前没有待审评论"
          : "没有评论";

      const body = document.createElement("p");
      body.className = "form-note";
      body.textContent = isDirectLookup
        ? `这条评论已处理，或不在“${statusLabels[status] ?? status}”筛选下。`
        : isPendingQueue
          ? "待审队列是空的，新的评论提交后会出现在这里。"
          : `没有符合条件的${statusLabels[status] ?? status}评论${getSearchSuffix(query)}。`;

      empty.append(title, body);
      return empty;
    }

    async function loadComments() {
      const token = getToken();
      if (!token) {
        setTokenPromptNote();
        return;
      }

      sessionStorage.setItem(storageKey, token);
      setNote("载入中。");
      if (list) list.innerHTML = "";

      try {
        const params = new URLSearchParams({ status: getStatus() });
        const query = getQuery();

        if (query) {
          params.set("q", query);
        }

        const response = await fetch(`/api/admin/comments?${params.toString()}`, {
          headers: { Authorization: `Bearer ${token}` }
        });
        const payload = await response.json();
        if (!response.ok) throw new Error(payload.message ?? "load failed");
        const comments = Array.isArray(payload.comments) ? payload.comments : [];
        renderStatusCounts(payload.counts);

        if (list) {
          list.innerHTML = "";
          if (comments.length) {
            for (const comment of comments) {
              list.append(renderComment(comment));
            }
          } else {
            list.append(renderEmptyState(getStatus(), query));
          }
        }

        const searchSuffix = getSearchSuffix(query);
        setNote(
          comments.length
            ? `已载入 ${comments.length} 条${statusLabels[getStatus()]}评论${searchSuffix}。`
            : getEmptyNoteMessage(getStatus(), query)
        );
      } catch (error) {
        const message = error instanceof Error && error.message ? error.message : "请检查 token 和环境变量。";
        setNote(`载入失败：${message}`);
      }
    }

    async function updateComment(id: string, status: string | undefined) {
      const token = getToken();
      if (!token || !status) return;
      const query = getQuery();
      const isDirectReviewAction = isCommentIdQuery(query) && ["approved", "rejected"].includes(status);

      setNote("更新中。");
      try {
        const response = await fetch("/api/admin/comments", {
          method: "PATCH",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify({ id, status })
        });
        const payload = await response.json();
        if (!response.ok) throw new Error(payload.message ?? "update failed");

        const updatedComment = payload.comment;

        if (isDirectReviewAction) {
          setStatus(status);
          updateLocationFilter(status, query);
        }

        setNote("已更新。");
        await loadComments();

        if (isDirectReviewAction) {
          const postSlug = typeof updatedComment?.post_slug === "string" ? updatedComment.post_slug : "";
          const resultMessage = reviewResultLabels[status] ?? "已处理这条评论。";
          setNote(
            resultMessage,
            postSlug ? { href: getPostUrl(postSlug), text: "查看文章" } : undefined
          );
        }
      } catch {
        setNote("更新失败。");
      }
    }

    if (form instanceof HTMLFormElement) {
      form.addEventListener("submit", (event) => {
        event.preventDefault();
        loadComments();
      });
    }

    for (const input of root?.querySelectorAll("[data-admin-status]") ?? []) {
      input.addEventListener("change", loadComments);
    }

    if (getToken()) {
      loadComments();
    } else {
      setTokenPromptNote();
    }
  </script>
</BaseLayout>
