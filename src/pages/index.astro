---
import PostList from "@components/PostList.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getAllTags, getPublishedPosts } from "@lib/posts";
import { site } from "@lib/site";

const posts = await getPublishedPosts();
const tags = await getAllTags();
---

<BaseLayout title={site.name} description={site.description}>
  <section class="intro" aria-labelledby="home-title">
    <div>
      <p class="eyebrow">Personal notes / slow thinking</p>
      <h1 id="home-title">把判断写慢一点。</h1>
      <p>{site.description}</p>
    </div>
    <aside class="index-mark" aria-label="博客索引">
      <strong>{posts.length.toString().padStart(2, "0")}</strong>
      <span>篇已发布文章</span>
      <span>{tags.length} 个标签</span>
    </aside>
  </section>

  <PostList posts={posts} />
</BaseLayout>
